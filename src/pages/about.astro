---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead title={`关于 · About | ${SITE_TITLE}`} description="" />
	</head>
	<body>
		<Header />
		<main>
			<article class="about">
				<p class="name" style="animation-delay:.15s">我叫乐言。这里是我为自己留出的一小块地方。</p>
				<p class="name-en" style="animation-delay:.15s">I'm 乐言 (Leyan). This is a small place I've kept for myself.</p>

				<p class="zh" style="animation-delay:.5s">写这些文字，是想给自己一个不赶路的时刻——用中文，也用英文，把日子重新过一遍，把匆忙里落下的东西，一点点捡回来。</p>
				<p class="en" style="animation-delay:.62s">I write here to give myself a moment that isn't in a hurry — to live the day over again, in Chinese and in English, and slowly pick up what got left behind along the way.</p>

				<p class="zh" style="animation-delay:.95s">这里没有更新计划，也不追逐什么。你会看到语言之间的缝隙、一些安静的观察、偶尔的占卜与阅读笔记，还有一些我想不明白、却还是想写下来的问题。</p>
				<p class="en" style="animation-delay:1.07s">There's no posting schedule here, and nothing being chased. You'll find the gaps between two languages, some quiet observations, the occasional note on divination or reading, and questions I can't answer but still want to write down.</p>

				<p class="zh" style="animation-delay:1.4s">如果你也在寻找一个不慌张的角落，欢迎留下来看看。</p>
				<p class="en" style="animation-delay:1.52s">If you're also looking for an unhurried corner, you're welcome to stay a while.</p>

				<div class="ending" style="animation-delay:2.3s">
					<hr class="rule" />
					<p class="zh close">世界是我看到的样子，也是你看到的样子。</p>
					<p class="echo" aria-hidden="true">世界是我看到的样子，也是你看到的样子。</p>
					<p class="en last">The world is as I see it — and as you see it, too.</p>
				</div>
			</article>
		</main>
		<Footer />

		<script>
			// 这一页知道现在几点：清晨/黄昏让倒影泛一点暖，深夜偏冷，白日中性
			const h = new Date().getHours();
			const tint =
				h >= 5 && h < 8 ? '#7d6244'
				: h >= 17 && h < 20 ? '#8a5e40'
				: h >= 20 || h < 5 ? '#4a5570'
				: '#1a1a1a';
			const el = document.querySelector('.about');
			if (el) el.style.setProperty('--tint', tint);
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
	}
	.about {
		--tint: #1a1a1a;
		max-width: 40rem;
		margin: 4rem auto;
		padding: 0 1.25rem;
	}

	/* 呼吸般地逐段浮起 */
	.about > * {
		opacity: 0;
		animation: fade-up 1s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
	}
	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: none;
		}
	}

	.name {
		font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif SC', 'Source Han Serif SC', serif;
		font-size: 1.25rem;
		letter-spacing: 0.02em;
		margin: 0 0 0.35rem;
	}
	.name-en {
		font-size: 0.8rem;
		line-height: 1.85;
		color: #9a9a94;
		margin: 0 0 2.4rem;
	}
	.zh {
		font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif SC', 'Source Han Serif SC', serif;
		font-size: 1.125rem;
		line-height: 2;
		color: #1a1a1a;
		margin: 0 0 0.35rem;
	}
	.en {
		font-size: 0.8rem;
		line-height: 1.85;
		color: #9a9a94;
		margin: 0 0 2rem;
	}

	.ending {
		margin-top: 0.6rem;
	}
	.rule {
		border: none;
		border-top: 0.5px solid rgba(0, 0, 0, 0.12);
		margin: 0;
	}
	.close {
		margin-top: 1.4rem;
		margin-bottom: 0;
	}
	.echo {
		font-family: Georgia, 'Times New Roman', 'Songti SC', 'Noto Serif SC', 'Source Han Serif SC', serif;
		font-size: 1.125rem;
		line-height: 2;
		color: var(--tint, #1a1a1a);
		transform: scaleY(-1);
		opacity: 0.15;
		margin: 4px 0 0;
		user-select: none;
		pointer-events: none;
		transition: opacity 0.7s ease;
		-webkit-mask-image: linear-gradient(to top, #000, transparent 72%);
		mask-image: linear-gradient(to top, #000, transparent 72%);
	}
	/* 镜子会认得光：光标移近结尾，倒影悄悄亮一下 */
	.ending:hover .echo {
		opacity: 0.3;
	}
	.last {
		margin-top: 0.2rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.about > * {
			opacity: 1;
			animation: none;
			transform: none;
		}
	}
</style>
